# Frontend environment variables for the React app.
# Copy this file to .env.local for local development.

# Use mock AI review in the browser without calling Supabase.
# Good for frontend-only demos.
VITE_USE_MOCK_AI_REVIEW=true

# Supabase project URL from Project Settings > API.
# Example: https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_URL=

# Edge Functions URL.
# Example: https://YOUR_PROJECT_REF.functions.supabase.co
VITE_SUPABASE_FUNCTIONS_URL=

# Public anon key from Supabase Project Settings > API.
# This is safe to expose in frontend code because Supabase RLS protects data.
VITE_SUPABASE_ANON_KEY=
